# Default dev DB (gitignored): path is relative to prisma/schema.prisma → prisma/dev.db
DATABASE_URL=file:./dev.db

# Optional: use the committed team DB at repo root (git-tracked): npm run db:push:shared then point Prisma here
# DATABASE_URL=file:../data/shared.db

# Local catalog (FragranceCatalog): after prisma db push, run: npx prisma db seed
# Large catalog (billable Apify runs): npm run catalog:bulk-apify -- --target=10000 --delay-ms=2500
# Import an Apify dataset / run into SQLite: npm run catalog:import-dataset -- <datasetId>
# Optional: APIFY_DATASET_ID=... then npm run catalog:import-dataset

# Apify - Fragrantica import (https://apify.com/lexis-solutions/fragrantica)
APIFY_TOKEN=

# Optional: different actor ID
# APIFY_FRAGRANTICA_ACTOR_ID=lexis-solutions/fragrantica

# Apify Proxy (helps if Fragrantica blocks runs)
# APIFY_USE_PROXY=true

# If set, the API will not automatically retry a failed/empty scrape with Apify proxy (default is one auto-retry).
# APIFY_NO_AUTO_PROXY_RETRY=true
